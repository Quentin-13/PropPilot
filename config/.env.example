# ============================================================
# PROPPILOT — Variables d'Environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# Les clés absentes activent automatiquement les mocks
# ============================================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (Whisper — transcription des appels) ---
OPENAI_API_KEY=sk-...

# --- Backblaze B2 (stockage audio des appels) ---
# Créez un bucket EU sur https://www.backblaze.com/b2/buckets.html
# Générez des Application Keys avec accès lecture+écriture sur ce bucket
B2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxx
B2_APPLICATION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
B2_BUCKET_NAME=proppilot-calls
B2_BUCKET_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# Endpoint S3-compatible — vérifiez dans la console B2 > Bucket > Endpoint
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# --- Mention légale RGPD (appels) ---
# URL d'un fichier audio pré-enregistré (optionnel — TTS utilisé si absent)
LEGAL_NOTICE_AUDIO_URL=
# true = utiliser TTS Twilio au lieu du fichier audio
FALLBACK_USE_TTS=true
# Texte lu aux appelants entrants
LEGAL_NOTICE_TEXT=Pour des raisons de qualité de service et de conformité, cet appel est susceptible d'être enregistré. En restant en ligne, vous acceptez ces conditions.
# Texte court joué à l'agent lors d'un appel sortant
LEGAL_NOTICE_SHORT_TEXT=Appel enregistré via PropPilot.

# --- Twilio (SMS + WhatsApp + Voice) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_NUMBER=+33xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886
# Numéros 07 dédiés disponibles dans le pool (séparés par des virgules)
# Configurez chaque numéro dans Twilio Console > Phone Numbers > Voice URL :
#   https://votre-domaine.fr/webhooks/twilio/voice/incoming
TWILIO_AVAILABLE_NUMBERS=+33757596114,+33757596190,+33757595675,+33757596799,+33757598770

# --- SendGrid (emails transactionnels) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@votreagence.fr
SENDGRID_FROM_NAME=PropPilot

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# --- Base de données (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost/proppilot

# --- Authentification JWT ---
JWT_SECRET_KEY=changeme-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- Stripe (facturation) ---
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Configuration Agence (agence de démo par défaut) ---
AGENCY_NAME=Mon Agence Immobilière
AGENCY_TIER=Starter
AGENCY_CLIENT_ID=client_001
AGENCY_COMMISSION_RATE=0.05
AGENCY_AVERAGE_PRICE=280000

# --- Admin ---
ADMIN_PASSWORD=changeme-in-production

# --- Mode ---
DEBUG=false
MOCK_MODE=auto
ENABLE_LEGACY_AGENTS=false

# --- URL API ---
API_URL=http://localhost:8000
