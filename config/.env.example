# ============================================================
# PROPPILOT — Variables d'Environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# Les clés absentes activent automatiquement les mocks
# ============================================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (DALL-E staging) ---
OPENAI_API_KEY=sk-...

# --- Twilio (SMS + WhatsApp + Voice) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+33xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# --- ElevenLabs (TTS voix française) ---
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- Retell AI (orchestration appels IA) ---
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SendGrid (emails transactionnels) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@votreagence.fr
SENDGRID_FROM_NAME=PropPilot

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Base de données ---
DATABASE_PATH=./data/agency.db

# --- Configuration Agence ---
AGENCY_NAME=Mon Agence Immobilière
AGENCY_TIER=Starter
AGENCY_CLIENT_ID=client_001
AGENCY_COMMISSION_RATE=0.05
AGENCY_AVERAGE_PRICE=280000

# --- Admin ---
ADMIN_PASSWORD=changeme-in-production

# --- Mode ---
DEBUG=false
MOCK_MODE=auto

# --- PropPilot ---
APP_NAME=PropPilot
APP_URL=https://proppilot.fr
SUPPORT_EMAIL=hello@proppilot.fr
